# ===========================================
# DATABASE CONNECTION
# ===========================================
# Local PostgreSQL (for development with Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# Production PostgreSQL (on your cPanel hosting)
# DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# Used for the contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=contact@imfathi.com

# ===========================================
# BUILD INSTRUCTIONS
# ===========================================
# 1. Set DATABASE_URL to your production PostgreSQL
# 2. Run: npm run db:fetch
# 3. Run: npm run build
# 4. Upload the 'build' folder to your cPanel www directory
